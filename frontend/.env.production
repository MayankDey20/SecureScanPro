# Production Environment Variables
# Update VITE_API_URL if deploying backend separately
# For docker/nginx deploy, keep it relative:
VITE_API_URL=/api/v1

# Supabase Realtime (optional — leave blank to disable)
# Find at: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
